{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "timetable/generate.php": {
      "runtime": "vercel-php@0.7.4"
    }
  },
  "routes": [
    {
      "src": "^/$",
      "dest": "/timetable/index.html"
    },
    {
      "src": "^/generate\\.php$",
      "dest": "/timetable/generate.php"
    },
    {
      "src": "^/timetable/(.*)$",
      "dest": "/timetable/$1"
    }
  ]
}
